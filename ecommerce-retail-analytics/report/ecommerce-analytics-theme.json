            "enableDetailDataLabel": false,
            "detailContentType": "Custom",
            "enableTitleDataLabel": false,
            "titleContentType": "Custom",
            "enableValueDataLabel": true,
            "optimizeLabelDisplay": false,
            "labelOverflow": true,
            "labelPosition": "OutsideEnd",
            "labelContentLayout": "SingleLine",
            "showBlankAs": "--",
            "detailShowBlankAs": "--",
            "titleShowBlankAs": "Unassigned",
            "transparency": 0,
            "wordWrap": false,
            "bold": false,
            "detailBold": false,
            "titleBold": false,
            "italic": false,
            "detailItalic": false,
            "titleItalic": false,
            "underline": false,
