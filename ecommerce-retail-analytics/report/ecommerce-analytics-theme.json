{
  "$schema": "https://powerbi.com/product/schema#reportTheme",
  "name": "E-Commerce Analytics Fluent",
  "_designNotes": "Fluent 2 inspired palette. Accent #0078D4 (Fluent Blue). Light grey canvas (#F3F2F1), white cards, subtle borders, drop-shadow off by default. Typography: Segoe UI / Segoe UI Semibold.",

  "dataColors": [
    "#0078D4",
    "#107C41",
    "#8764B8",
    "#D83B01",
    "#00B7C3",
    "#CA5010",
    "#0F6CBD",
    "#498205",
    "#C239B3",
    "#E3008C",
    "#5C2E91",
    "#038387",
    "#A4373A"
  ],

  "good": "#107C41",
  "neutral": "#605E5C",
  "bad": "#D13438",
  "maximum": "#0078D4",
  "center": "#FFB900",
  "minimum": "#DEECF9",
  "null": "#EDEBE9",

  "firstLevelElements": "#201F1E",
  "secondLevelElements": "#605E5C",
  "thirdLevelElements": "#EDEBE9",
  "fourthLevelElements": "#A19F9D",
  "foreground": "#201F1E",
  "foregroundLight": "#605E5C",
  "foregroundDark": "#201F1E",
  "foregroundNeutralLight": "#A19F9D",
  "foregroundNeutralDark": "#201F1E",
  "foregroundNeutralSecondary": "#605E5C",
  "foregroundNeutralSecondaryAlt": "#605E5C",
  "foregroundNeutralSecondaryAlt2": "#605E5C",
  "foregroundNeutralTertiary": "#A19F9D",
  "foregroundNeutralTertiaryAlt": "#A19F9D",
  "foregroundSelected": "#0078D4",
  "foregroundButton": "#FFFFFF",

  "background": "#F3F2F1",
  "backgroundLight": "#FFFFFF",
  "backgroundNeutral": "#FAF9F8",
  "backgroundDark": "#201F1E",
  "secondaryBackground": "#FFFFFF",

  "shapeStroke": "#EDEBE9",
  "accent": "#0078D4",
  "tableAccent": "#0078D4",
  "hyperlink": "#0078D4",
  "visitedHyperlink": "#5C2E91",
  "disabledText": "#A19F9D",
  "mapPushpin": "#0078D4",

  "textClasses": {
    "title":            { "fontSize": 14, "fontFace": "Segoe UI Semibold", "color": "#201F1E" },
    "label":            { "fontSize": 11, "fontFace": "Segoe UI",          "color": "#605E5C" },
    "callout":          { "fontSize": 28, "fontFace": "Segoe UI Semibold", "color": "#201F1E" },
    "header":           { "fontSize": 12, "fontFace": "Segoe UI Semibold", "color": "#201F1E" },
    "largeTitle":       { "fontSize": 20, "fontFace": "Segoe UI Semibold", "color": "#201F1E" },
    "dataTitle":        { "fontSize": 12, "fontFace": "Segoe UI",          "color": "#605E5C" },
    "boldLabel":        { "fontSize": 12, "fontFace": "Segoe UI Semibold", "color": "#201F1E" },
    "largeLabel":       { "fontSize": 14, "fontFace": "Segoe UI Semibold", "color": "#201F1E" },
    "largeLightLabel":  { "fontSize": 14, "fontFace": "Segoe UI",          "color": "#605E5C" },
    "lightLabel":       { "fontSize": 11, "fontFace": "Segoe UI",          "color": "#605E5C" },
    "semiboldLabel":    { "fontSize": 11, "fontFace": "Segoe UI Semibold", "color": "#201F1E" },
    "smallLabel":       { "fontSize": 10, "fontFace": "Segoe UI",          "color": "#605E5C" },
    "smallLightLabel":  { "fontSize": 10, "fontFace": "Segoe UI",          "color": "#A19F9D" },
    "smallDataLabel":   { "fontSize": 10, "fontFace": "Segoe UI",          "color": "#605E5C" }
  },

  "visualStyles": {
    "*": {
      "*": {
        "*": [
          {
            "wordWrap": false,
            "rectangleRoundedCurve": 6,
            "roundEdge": 6
          }
        ],
        "general": [{ "responsive": false, "responsiveLegacy": false }],
        "outline": [{ "transparency": 0 }],
        "dataPoint": [
          {
            "Transparency": 0,
            "fillTransparency": 0,
            "borderColorMatchFill": true,
            "borderOutlineOnly": false,
            "borderShow": false,
            "borderSize": 1
          }
        ],
        "categoryAxis": [
          {
            "showAxisTitle": false,
            "gridlineShow": false,
            "concatenateLabels": false,
            "labelColor": { "solid": { "color": "#605E5C" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "valueAxis": [
          {
            "show": true,
            "showAxisTitle": false,
            "gridlineShow": true,
            "gridlineColor": { "solid": { "color": "#EDEBE9" } },
            "gridlineStyle": "solid",
            "gridlineThickness": 1,
            "fontFamily": "Segoe UI",
            "fontSize": 10,
            "labelColor": { "solid": { "color": "#605E5C" } }
          }
        ],
        "y2Axis": [{ "show": false }],
        "title": [
          {
            "show": true,
            "alignment": "left",
            "titleWrap": true,
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 13,
            "fontColor": { "solid": { "color": "#201F1E" } }
          }
        ],
        "subTitle": [
          {
            "show": false,
            "alignment": "left",
            "fontFamily": "Segoe UI",
            "fontSize": 10,
            "fontColor": { "solid": { "color": "#605E5C" } }
          }
        ],
        "divider": [{ "show": false }],
        "padding": [{ "top": 12, "bottom": 12, "left": 16, "right": 16 }],
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "width": 1,
            "color": { "solid": { "color": "#EDEBE9" } },
            "radius": 6
          }
        ],
        "_comment_dropShadow": "Drop shadow disabled globally per Fluent 2 guidelines; cards rely on subtle border instead.",
        "dropShadow": [
          {
            "show": false,
            "preset": "Custom",
            "angle": 90,
            "color": { "solid": { "color": "#000000" } },
            "position": "Outer",
            "shadowBlur": 2,
            "shadowDistance": 1,
            "transparency": 96
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": { "solid": { "color": "#FAF9F8" } },
            "transparency": 0,
            "border": true,
            "borderColor": { "solid": { "color": "#EDEBE9" } }
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "transparency": 0,
            "foregroundColor": { "solid": { "color": "#201F1E" } },
            "border": true
          },
          {
            "$id": "Available",
            "transparency": 0,
            "foregroundColor": { "solid": { "color": "#605E5C" } },
            "border": true
          }
        ],
        "lineStyles": [
          {
            "areaShow": false,
            "showMarker": false,
            "markerSize": 3,
            "markerShape": "circle",
            "strokeShow": true,
            "strokeWidth": 2,
            "lineStyle": "solid",
            "lineChartType": "smooth"
          }
        ],
        "labels": [
          {
            "fontFamily": "Segoe UI",
            "fontSize": 10,
            "show": true,
            "color": { "solid": { "color": "#201F1E" } },
            "transparency": 0
          }
        ],
        "markers": [
          {
            "borderColor": { "solid": { "color": "#FFFFFF" } },
            "borderShow": true,
            "borderTransparency": 0,
            "borderWidth": 1,
            "transparency": 0
          }
        ],
        "legend": [
          {
            "show": true,
            "position": "Top",
            "labelColor": { "solid": { "color": "#605E5C" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "visualHeader": [
          { "foreground": { "solid": { "color": "#605E5C" } } }
        ]
      }
    },

    "actionButton": {
      "*": {
        "background": [{ "show": false }],
        "visualHeader": [{ "show": false }],
        "border": [{ "show": false }],
        "dropShadow": [{ "show": false }]
      }
    },

    "advancedSlicerVisual": {
      "*": {
        "layout": [{ "maxTiles": 3, "cellPadding": 4, "columnCount": 3, "rowCount": 1 }],
        "shapeCustomRectangle": [{ "tileShape": "rectangleRoundedByPixel", "rectangleRoundedCurve": 6 }],
        "value": [{ "show": true, "fontSize": 11, "horizontalAlignment": "center", "verticalAlignment": "middle", "bold": true }],
        "selection": [{ "singleSelect": true }],
        "outline": [{ "show": true, "weight": 1 }]
      }
    },

    "areaChart": {
      "*": {
        "labels": [{ "show": false }]
      }
    },

    "barChart": {
      "*": {
        "legend": [
          { "show": true, "showTitle": false, "fontSize": 9, "position": "Right" }
        ],
        "dataPoint": [
          { "fillTransparency": 0, "borderShow": false }
        ],
        "labels": [
          {
            "show": true,
            "enableValueDataLabel": true,
            "color": { "solid": { "color": "#605E5C" } },
            "labelPosition": "OutsideEnd",
            "bold": false,
            "italic": false,
            "underline": false
          }
        ],
        "valueAxis": [{ "show": false }]
      }
    },

    "bookmarkNavigator": {
      "*": {
        "background": [{ "show": false }],
        "visualHeader": [{ "show": false }],
        "border": [{ "show": false }],
        "dropShadow": [{ "show": false }]
      }
    },

    "card": {
      "*": {
        "general": [{ "formatString": "#,##0" }],
        "categoryLabels": [
          {
            "show": true,
            "color": { "solid": { "color": "#605E5C" } },
            "fontFamily": "Segoe UI",
            "fontSize": 11
          }
        ],
        "labels": [
          {
            "show": true,
            "color": { "solid": { "color": "#0078D4" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 28,
            "labelPrecision": 1
          }
        ],
        "subTitle": [{ "show": false }],
        "divider": [{ "show": false }],
        "padding": [{ "top": 16, "bottom": 16, "left": 18, "right": 18 }]
      }
    },

    "cardVisual": {
      "*": {
        "layout": [{ "maxTiles": 3 }],
        "overflow": [{ "type": 0 }]
      }
    },

    "clusteredBarChart": {
      "*": {
        "general": [{ "responsive": true }],
        "legend": [{ "showGradientLegend": false }]
      }
    },

    "clusteredColumnChart": {
      "*": {
        "general": [{ "responsive": true }],
        "legend": [{ "showGradientLegend": false }]
      }
    },

    "columnChart": {
      "*": {
        "general": [{ "responsive": true }]
      }
    },

    "donutChart": {
      "*": {
        "legend": [{ "show": true, "position": "RightCenter" }],
        "labels": [{ "labelStyle": "Data value, percent of total" }]
      }
    },

    "funnel": {
      "*": {
        "labels": [{ "show": true }]
      }
    },

    "group": {
      "*": {
        "background": [{ "show": false }],
        "border": [{ "show": false }],
        "dropShadow": [{ "show": false }]
      }
    },

    "image": {
      "*": {
        "title": [{ "show": false }],
        "subTitle": [{ "show": false }],
        "background": [{ "show": false }],
        "border": [{ "show": false }],
        "dropShadow": [{ "show": false }],
        "divider": [{ "show": false }],
        "visualHeader": [{ "show": false }],
        "lockAspect": [{ "show": true }]
      }
    },

    "lineChart": {
      "*": {
        "labels": [{ "show": false }],
        "lineStyles": [
          {
            "strokeWidth": 3,
            "lineChartType": "smooth",
            "markerShape": "circle",
            "markerSize": 4
          }
        ]
      }
    },

    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#F3F2F1" } },
            "transparency": 0
          }
        ],
        "wallpaper": [
          { "color": { "solid": { "color": "#F3F2F1" } } }
        ],
        "displayArea": [{ "verticalAlignment": "Top" }],
        "filterCard": [
          {
            "backgroundColor": { "solid": { "color": "#FFFFFF" } },
            "border": true,
            "borderColor": { "solid": { "color": "#EDEBE9" } },
            "fontFamily": "Segoe UI",
            "foregroundColor": { "solid": { "color": "#201F1E" } },
            "inputBoxColor": { "solid": { "color": "#FFFFFF" } },
            "textSize": 11,
            "transparency": 0
          }
        ],
        "outspace": [
          { "color": { "solid": { "color": "#F3F2F1" } }, "transparency": 0 }
        ],
        "pageSize": [
          { "pageSizeTypes": "Custom", "pageSizeHeight": 1080, "pageSizeWidth": 1920 }
        ]
      }
    },

    "pageNavigator": {
      "*": {
        "background": [{ "show": false }],
        "visualHeader": [{ "show": false }],
        "border": [{ "show": false }],
        "dropShadow": [{ "show": false }]
      }
    },

    "pieChart": {
      "*": {
        "legend": [{ "show": true, "position": "RightCenter" }],
        "labels": [{ "labelStyle": "Data value, percent of total" }]
      }
    },

    "pivotTable": {
      "*": {
        "columnHeaders": [
          {
            "alignment": "Left",
            "backColor": { "solid": { "color": "#FAF9F8" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11,
            "fontColor": { "solid": { "color": "#201F1E" } },
            "outlineColor": { "solid": { "color": "#EDEBE9" } },
            "outlineStyle": 1,
            "outlineWeight": 1,
            "wordWrap": false
          }
        ],
        "rowHeaders": [
          {
            "alignment": "Left",
            "backColor": { "solid": { "color": "#FFFFFF" } },
            "fontFamily": "Segoe UI",
            "fontSize": 11,
            "fontColor": { "solid": { "color": "#201F1E" } },
            "outlineColor": { "solid": { "color": "#EDEBE9" } },
            "outlineStyle": 1,
            "outlineWeight": 1,
            "stepped": true,
            "steppedLayoutIndentation": 16
          }
        ],
        "grid": [
          {
            "gridHorizontal": true,
            "gridHorizontalColor": { "solid": { "color": "#EDEBE9" } },
            "gridHorizontalWeight": 1,
            "gridVertical": false,
            "outlineColor": { "solid": { "color": "#EDEBE9" } },
            "outlineStyle": 0,
            "outlineWeight": 0,
            "rowPadding": 6,
            "textSize": 11
          }
        ],
        "values": [
          {
            "backColor": { "solid": { "color": "#FFFFFF" } },
            "backColorPrimary": { "solid": { "color": "#FFFFFF" } },
            "backColorSecondary": { "solid": { "color": "#FAF9F8" } },
            "fontColor": { "solid": { "color": "#201F1E" } },
            "fontFamily": "Segoe UI",
            "fontSize": 11
          }
        ],
        "total": [
          {
            "totals": true,
            "backColor": { "solid": { "color": "#EFF6FC" } },
            "fontColor": { "solid": { "color": "#0078D4" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11
          }
        ],
        "subTotals": [
          {
            "columnSubtotals": true,
            "rowSubtotals": true,
            "rowSubtotalsPosition": "Top",
            "backColor": { "solid": { "color": "#FAF9F8" } },
            "fontColor": { "solid": { "color": "#201F1E" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11
          }
        ]
      }
    },

    "ribbonChart": {
      "*": {
        "labels": [{ "show": false }]
      }
    },

    "scatterChart": {
      "*": {
        "bubbles": [{ "bubbleSize": -5, "markerRangeType": "auto" }],
        "general": [{ "responsive": true }],
        "fillPoint": [{ "show": true }],
        "labels": [{ "show": false }]
      }
    },

    "shape": {
      "*": {
        "background": [{ "show": false }],
        "border": [{ "show": false }],
        "dropShadow": [{ "show": false }],
        "visualHeader": [{ "show": false }]
      }
    },

    "slicer": {
      "*": {
        "general": [{ "responsive": true }],
        "date": [{ "hideDatePickerButton": false }],
        "items": [{ "padding": 6, "accessibilityContrastProperties": true }]
      }
    },

    "stackedAreaChart": {
      "*": {
        "labels": [{ "show": false }]
      }
    },

    "tableEx": {
      "*": {
        "columnHeaders": [
          {
            "alignment": "Left",
            "backColor": { "solid": { "color": "#FAF9F8" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11,
            "fontColor": { "solid": { "color": "#201F1E" } },
            "outlineColor": { "solid": { "color": "#EDEBE9" } },
            "outlineStyle": 1,
            "outlineWeight": 1,
            "wordWrap": false
          }
        ],
        "grid": [
          {
            "gridHorizontal": true,
            "gridHorizontalColor": { "solid": { "color": "#EDEBE9" } },
            "gridHorizontalWeight": 1,
            "gridVertical": false,
            "outlineColor": { "solid": { "color": "#EDEBE9" } },
            "outlineStyle": 0,
            "outlineWeight": 0,
            "rowPadding": 8,
            "textSize": 11
          }
        ],
        "values": [
          {
            "backColor": { "solid": { "color": "#FFFFFF" } },
            "backColorPrimary": { "solid": { "color": "#FFFFFF" } },
            "backColorSecondary": { "solid": { "color": "#FAF9F8" } },
            "fontColor": { "solid": { "color": "#201F1E" } },
            "fontFamily": "Segoe UI",
            "fontSize": 11
          }
        ],
        "total": [
          {
            "totals": true,
            "backColor": { "solid": { "color": "#EFF6FC" } },
            "fontColor": { "solid": { "color": "#0078D4" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11
          }
        ]
      }
    },

    "textbox": {
      "*": {
        "general": [{ "keepLayerOrder": true }],
        "title": [{ "show": false }],
        "subTitle": [{ "show": false }],
        "divider": [{ "show": false }],
        "background": [{ "show": false }],
        "border": [{ "show": false }],
        "dropShadow": [{ "show": false }],
        "visualHeader": [{ "show": false }]
      }
    },

    "treemap": {
      "*": {
        "general": [{ "responsive": true }]
      }
    },

    "waterfallChart": {
      "*": {
        "valueAxis": [{ "show": false }],
        "legend": [{ "show": false }],
        "sentimentColors": [
          { "totalFill": { "solid": { "color": "#A19F9D" } } }
        ]
      }
    }
  }
}
