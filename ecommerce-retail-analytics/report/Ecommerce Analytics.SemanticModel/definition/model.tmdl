model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["_Measures","DIM_COHORTS","DIM_CUSTOMERS","DIM_DATES","DIM_PRODUCTS","DIM_SELLERS","FCT_CATEGORY_PERFORMANCE","FCT_CHURN_RISK","FCT_CLV_CUSTOMER","FCT_COHORT_RETENTION","FCT_DAILY_REVENUE_TIME_SERIES","FCT_GEO_PERFORMANCE","FCT_MARKET_BASKET","FCT_ORDER_ITEMS","FCT_ORDERS","FCT_ORDERS_FUNNEL","FCT_PARETO_PRODUCTS","FCT_PAYMENT_ANALYSIS","FCT_RFM_SEGMENTS"]

annotation PBI_ProTooling = ["DevMode"]

ref table _Measures
ref table DIM_COHORTS
ref table DIM_CUSTOMERS
ref table DIM_DATES
ref table DIM_PRODUCTS
ref table DIM_SELLERS
ref table FCT_CATEGORY_PERFORMANCE
ref table FCT_CHURN_RISK
ref table FCT_CLV_CUSTOMER
ref table FCT_COHORT_RETENTION
ref table FCT_DAILY_REVENUE_TIME_SERIES
ref table FCT_GEO_PERFORMANCE
ref table FCT_MARKET_BASKET
ref table FCT_ORDER_ITEMS
ref table FCT_ORDERS
ref table FCT_ORDERS_FUNNEL
ref table FCT_PARETO_PRODUCTS
ref table FCT_PAYMENT_ANALYSIS
ref table FCT_RFM_SEGMENTS

ref cultureInfo en-US

